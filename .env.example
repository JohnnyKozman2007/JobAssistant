# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get your URL and secret key at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ─── Internal service URLs (Docker) ───────────────────────────────────────────
AGENT_BASE_URL=http://agent:8001
BACKEND_BASE_URL=http://backend:8000

# ─── Google AI ────────────────────────────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ─── LangSmith ────────────────────────────────────────────────────────────────
# Get your API key at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=resume-scorer
